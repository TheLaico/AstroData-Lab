# Conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
URL_BASE_DATOS=postgresql://usuario:contraseña@localhost:5432/astrodata

# SSL: "disable" para PostgreSQL local, "require" para servicios en la nube (Neon, Supabase, etc.)
DB_SSL=disable

# Modelos de embeddings
MODELO_TEXTO=all-MiniLM-L6-v2
MODELO_IMAGEN=openai/clip-vit-base-patch32

# Número de resultados vectoriales por defecto
TOP_K=5

# Estrategia de chunking: fixed | sentence | semantic
ESTRATEGIA_CHUNKING=sentence

# Dimensiones de los vectores (deben coincidir con el modelo elegido)
DIMENSION_VECTOR_TEXTO=384
DIMENSION_VECTOR_IMAGEN=512
