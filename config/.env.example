# Configuracion local de AstroData Lab
# Copia este archivo como config/.env y ajusta los valores.

URL_BASE_DATOS=postgresql://usuario:contrasena@localhost:5432/astrodata
DB_SSL=disable

MODELO_TEXTO=all-MiniLM-L6-v2
MODELO_IMAGEN=openai/clip-vit-base-patch32
TOP_K=5
ESTRATEGIA_CHUNKING=sentence
DIMENSION_VECTOR_TEXTO=384
DIMENSION_VECTOR_IMAGEN=512
