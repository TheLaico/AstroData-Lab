# PLANTILLA DE VARIABLES DE ENTORNO - ASTRODATA LAB
#════════════════════════════════════════════════════════════════════════════════════════════════════
#
# Este archivo es una plantilla de ejemplo que muestra todas las variables
# de entorno requeridas y opcionales por la aplicación AstroData Lab.
#
# INSTRUCCIONES:
# 1. Copia este archivo como ".env" en el mismo directorio
# 2. Actualiza los valores según tu configuración local
# 3. NUNCA subas el archivo .env al repositorio (ya está en .gitignore)
# 4. Las variables marcadas como [REQUERIDA] deben tener valores válidos
# 5. Las variables marcadas como [OPCIONAL] tienen valores por defecto
#
#════════════════════════════════════════════════════════════════════════════════════════════════════


#════════════════════════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE BASE DE DATOS
#════════════════════════════════════════════════════════════════════════════════════════════════════

# URL de conexión asincrónica a PostgreSQL con pgvector
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/base_datos
# [REQUERIDA]
URL_BASE_DATOS=postgresql+asyncpg://astrodata:contraseña_segura@localhost:5432/astrodata_lab


#════════════════════════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE MODELOS DE EMBEDDINGS
#════════════════════════════════════════════════════════════════════════════════════════════════════

# Modelo de embeddings para texto (sentence-transformers)
# Recomendado: 'all-MiniLM-L6-v2' (384 dimensiones, rápido y eficiente)
# Alternativas: 'all-mpnet-base-v2' (768 dim), 'all-roberta-large-v1' (1024 dim)
# [OPCIONAL] Default: 'all-MiniLM-L6-v2'
MODELO_TEXTO=all-MiniLM-L6-v2

# Modelo CLIP para embeddings de imágenes astronómicas
# Recomendado: 'openai/clip-vit-base-patch32' (512 dimensiones)
# Alternativas: 'openai/clip-vit-large-patch14' (768 dim), 'openai/clip-vit-base-patch16' (512 dim)
# [OPCIONAL] Default: 'openai/clip-vit-base-patch32'
MODELO_IMAGEN=openai/clip-vit-base-patch32


#════════════════════════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE RECUPERACIÓN DE VECTORES
#════════════════════════════════════════════════════════════════════════════════════════════════════

# Número de resultados vectoriales a recuperar por defecto en búsquedas RAG
# Rango recomendado: 3-20 (más resultados = más contexto pero más tiempo)
# [OPCIONAL] Default: 5
TOP_K=5


#════════════════════════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE CHUNKING DE DOCUMENTOS
#════════════════════════════════════════════════════════════════════════════════════════════════════

# Estrategia de división de documentos en chunks
# Valores permitidos:
#   - 'fixed': divide en fragmentos de tamaño fijo (rápido pero menos semántico)
#   - 'sentence': respeta límites de oración (recomendado para astronomía)
#   - 'semantic': divide por similitud semántica (más lento, muy preciso)
# [OPCIONAL] Default: 'sentence'
ESTRATEGIA_CHUNKING=sentence


#════════════════════════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE DIMENSIONES DE VECTORES
#════════════════════════════════════════════════════════════════════════════════════════════════════

# Dimensión de los embeddings de texto (debe coincidir con el modelo seleccionado)
# all-MiniLM-L6-v2 → 384
# all-mpnet-base-v2 → 768
# all-roberta-large-v1 → 1024
# [OPCIONAL] Default: 384
DIMENSION_VECTOR_TEXTO=384

# Dimensión de los embeddings de imagen (debe coincidir con el modelo CLIP)
# openai/clip-vit-base-patch32 → 512
# openai/clip-vit-large-patch14 → 768
# [OPCIONAL] Default: 512
DIMENSION_VECTOR_IMAGEN=512
